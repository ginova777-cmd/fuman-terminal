{
  "strategy": "institution",
  "contract": "institution-decision-gate-matrix-v1",
  "gates": [
    {
      "gateName": "chip_authority_ready",
      "gatePayloadPath": "institution_source_status_at_run.coverageStatus",
      "scannerPayloadPath": "scannerOutput.sourceStatusAtRun.coverageStatus",
      "apiPayloadPath": "institution_source_status_at_run.coverageStatus",
      "writerPayloadPath": "run.payload.institution_source_status_at_run.coverageStatus",
      "sourceTableOrView": "v_institution_source_health / v_chip_flows_latest",
      "businessPurpose": "買賣超核心 authority 必須 ready 才可正式 publish",
      "requiredForScan": true,
      "requiredForPublish": true,
      "requiredForFormalEntry": true,
      "allowedStates": ["ready"],
      "blockedStates": ["blocked", "degraded", "timeout", "error", "missing"],
      "whenBlockedReason": "institution_chip_authority_not_ready",
      "fallbackAllowed": false,
      "fallbackScopeAllowed": [],
      "blockLatestWhenFailed": true,
      "preservePreviousGoodWhenFailed": true,
      "verifierRule": "coverageStatus must be ready before publishAllowed=true",
      "negativeTestName": "missing-institution-chip-source-status",
      "sampleFailureExpected": "missing_institution_chip_source_status"
    },
    {
      "gateName": "institutional_rows_ready",
      "gatePayloadPath": "institution_source_status_at_run.institutionalRows",
      "scannerPayloadPath": "scannerOutput.sourceCount",
      "apiPayloadPath": "institution_source_status_at_run.institutionalRows",
      "writerPayloadPath": "run.payload.institution_source_status_at_run.institutionalRows",
      "sourceTableOrView": "v_institution_source_health.institutional_rows",
      "businessPurpose": "正式買賣超樣本覆蓋門檻",
      "requiredForScan": true,
      "requiredForPublish": true,
      "requiredForFormalEntry": true,
      "allowedStates": [">=1500"],
      "blockedStates": ["<1500", "missing"],
      "whenBlockedReason": "institutional_rows_below_min",
      "fallbackAllowed": false,
      "fallbackScopeAllowed": [],
      "blockLatestWhenFailed": true,
      "preservePreviousGoodWhenFailed": true,
      "verifierRule": "institutionalRows >= 1500 or publishAllowed must be false",
      "negativeTestName": "institutionalRows-lt-1500-publishAllowed-true",
      "sampleFailureExpected": "institutionalRows_below_1500_but_publishAllowed_true"
    },
    {
      "gateName": "margin_optional_or_required",
      "gatePayloadPath": "sourceCoverage.marginRows",
      "scannerPayloadPath": "scannerOutput.sourceHealth.marginRows",
      "apiPayloadPath": "sourceCoverage.marginRows",
      "writerPayloadPath": "run.payload.sourceCoverage.marginRows",
      "sourceTableOrView": "v_institution_source_health.margin_rows",
      "businessPurpose": "融資券僅為輔助揭露；Institution 核心 authority 是 chip/institutional",
      "requiredForScan": false,
      "requiredForPublish": false,
      "requiredForFormalEntry": false,
      "allowedStates": ["not_required", "ready", "missing_when_not_used"],
      "blockedStates": ["required_but_missing"],
      "whenBlockedReason": "margin_not_required_for_institution_chip_authority",
      "fallbackAllowed": false,
      "fallbackScopeAllowed": [],
      "blockLatestWhenFailed": false,
      "preservePreviousGoodWhenFailed": false,
      "verifierRule": "marginRows is not required unless strategy code marks margin as required",
      "negativeTestName": "margin-required-missing",
      "sampleFailureExpected": "margin_required_missing"
    },
    {
      "gateName": "valid_after_exclusion_ready",
      "gatePayloadPath": "institution_source_status_at_run.validAfterExclusionRows",
      "scannerPayloadPath": "scannerOutput.count",
      "apiPayloadPath": "institution_source_status_at_run.validAfterExclusionRows",
      "writerPayloadPath": "run.payload.institution_source_status_at_run.validAfterExclusionRows",
      "sourceTableOrView": "v_institution_source_health.valid_after_exclusion_rows",
      "businessPurpose": "排除黑名單後仍需達 A 級覆蓋門檻",
      "requiredForScan": true,
      "requiredForPublish": true,
      "requiredForFormalEntry": true,
      "allowedStates": [">=1500"],
      "blockedStates": ["<1500", "missing"],
      "whenBlockedReason": "valid_after_exclusion_rows_below_min",
      "fallbackAllowed": false,
      "fallbackScopeAllowed": [],
      "blockLatestWhenFailed": true,
      "preservePreviousGoodWhenFailed": true,
      "verifierRule": "validAfterExclusionRows >= 1500 or unattendedStatus must not be YES",
      "negativeTestName": "validAfterExclusionRows-lt-1500-unattended-yes",
      "sampleFailureExpected": "validAfterExclusionRows_below_1500_but_unattendedStatus_yes"
    },
    {
      "gateName": "readback_count_match",
      "gatePayloadPath": "run_quality_at_publish.readbackCount",
      "scannerPayloadPath": "scannerOutput.readbackCount",
      "apiPayloadPath": "run_quality_at_publish.readbackCount",
      "writerPayloadPath": "run.payload.run_quality_at_publish.readbackCount",
      "sourceTableOrView": "institution_scan_results / v_institution_latest_complete_run",
      "businessPurpose": "writer 完成後 readback 必須等於 resultCount，避免空結果或半套 publish",
      "requiredForScan": false,
      "requiredForPublish": true,
      "requiredForFormalEntry": true,
      "allowedStates": ["readbackCount == resultCount"],
      "blockedStates": ["readbackCount != resultCount", "missing"],
      "whenBlockedReason": "readback_count_mismatch",
      "fallbackAllowed": false,
      "fallbackScopeAllowed": [],
      "blockLatestWhenFailed": true,
      "preservePreviousGoodWhenFailed": true,
      "verifierRule": "readbackCount equals resultCount",
      "negativeTestName": "empty-result-updates-latest-pointer",
      "sampleFailureExpected": "empty_result_updated_latest_pointer"
    }
  ]
}
