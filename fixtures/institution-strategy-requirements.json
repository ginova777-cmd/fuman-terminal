{
  "strategy": "institution",
  "contract": "institution-strategy-requirements-v1",
  "strategyName": "買賣超 / Institution",
  "strategyPurpose": "找出三大法人籌碼轉強、外資/投信/同買、連買與外資+投信佔量強的股票。",
  "formalPublishDefinition": "chip / institutional authority ready、coverageStatus=ready、institutionalRows 與 validAfterExclusionRows 皆 >= 1500、result/readback complete、fallback 未污染 latest 時，才可 publish latest。",
  "plainLanguage": {
    "pattern": "籌碼轉強：外資買超、投信買超、外資+投信同買、連買日、法人合計買超、外資+投信買超佔近 5 日均量偏高。",
    "scanAllowedWhen": "盤後 institutional / chip source 更新完成後；核心來源是 TWSE T86 / TPEx 3itrade 對應的 chip / institutional source。",
    "scanBlockedWhen": "chip source timeout、coverageStatus 非 ready、institutionalRows < 1500、validAfterExclusionRows < 1500、latestTradeDate / usedDate 缺失、source status 缺欄、Supabase 522/timeout。",
    "publishAllowedWhen": "source ready、scan complete、resultRows/readbackCount 合理、requiredFields 無缺、fallbackUsed=false 或 fallback 不影響 formal publish、writeBudget 允許。",
    "preservePreviousGoodWhen": "source not ready、empty result 但 source 未 ready、fallback display-only、Supabase timeout/522、readback mismatch、blocked/degraded run。"
  },
  "allowedFailureActions": ["block scan", "block publish", "preserve previous good", "write blocked receipt", "display degraded", "fail closed"],
  "conditions": [
    { "conditionId": "C01", "conditionName": "chip authority ready", "purpose": "判斷買賣超核心來源能不能用", "requiredFields": ["institution_source_status_at_run", "chip_source_status_at_run"], "sourceTableOrView": "v_institution_source_health / v_chip_flows_latest", "passCriteria": "status=ready", "failCriteria": "missing / timeout / 522 / degraded", "failureActions": ["block scan", "block publish", "preserve previous good", "write blocked receipt", "fail closed"] },
    { "conditionId": "C02", "conditionName": "coverage ready", "purpose": "判斷覆蓋是否足夠", "requiredFields": ["coverageStatus"], "sourceTableOrView": "v_institution_source_health", "passCriteria": "coverageStatus=ready", "failCriteria": "coverageStatus!=ready", "failureActions": ["block publish", "preserve previous good", "write blocked receipt", "fail closed"] },
    { "conditionId": "C03", "conditionName": "institutionalRows threshold", "purpose": "確認原始法人筆數足夠", "requiredFields": ["institutionalRows"], "sourceTableOrView": "v_institution_source_health", "passCriteria": "institutionalRows >= 1500", "failCriteria": "institutionalRows < 1500", "failureActions": ["block publish", "preserve previous good", "write blocked receipt", "fail closed"] },
    { "conditionId": "C04", "conditionName": "validAfterExclusionRows threshold", "purpose": "確認排除 ETF/權證/CB 後仍足夠", "requiredFields": ["validAfterExclusionRows"], "sourceTableOrView": "scanner output / source health", "passCriteria": "validAfterExclusionRows >= 1500", "failCriteria": "validAfterExclusionRows < 1500", "failureActions": ["block publish", "preserve previous good", "write blocked receipt", "fail closed"] },
    { "conditionId": "C05", "conditionName": "trade date ready", "purpose": "確認資料日期可定位", "requiredFields": ["latestTradeDate", "usedDate"], "sourceTableOrView": "source health / scanner output", "passCriteria": "8 digit date exists", "failCriteria": "missing / mismatch without disclosure", "failureActions": ["block publish", "write blocked receipt", "fail closed"] },
    { "conditionId": "C06", "conditionName": "result complete", "purpose": "確認掃描結果完整", "requiredFields": ["resultRows", "resultCount", "scannedCount"], "sourceTableOrView": "scanner output / run payload", "passCriteria": "complete and count reasonable", "failCriteria": "incomplete / missing", "failureActions": ["block publish", "preserve previous good", "fail closed"] },
    { "conditionId": "C07", "conditionName": "readback match", "purpose": "確認 writer 寫入後可讀回", "requiredFields": ["readbackCount", "resultCount"], "sourceTableOrView": "run payload / battle output", "passCriteria": "readbackCount == resultCount", "failCriteria": "mismatch / missing", "failureActions": ["block publish", "preserve previous good", "write blocked receipt", "fail closed"] },
    { "conditionId": "C08", "conditionName": "required fields complete", "purpose": "防止畫面/排序欄位缺失", "requiredFields": ["requiredFields", "blankCounts", "sampleMissingRows"], "sourceTableOrView": "run_quality_at_publish", "passCriteria": "required blankCounts=0", "failCriteria": "required 欄位空白", "failureActions": ["block publish", "preserve previous good", "display degraded", "fail closed"] },
    { "conditionId": "C09", "conditionName": "fallback disclosure", "purpose": "防止 fallback 假裝正式", "requiredFields": ["fallbackUsed", "fallbackScope", "fallbackDetails", "fallbackContract"], "sourceTableOrView": "API / scanner / receipt", "passCriteria": "fallback 欄位完整", "failCriteria": "fallbackUsed=true but contract/details missing", "failureActions": ["block publish", "preserve previous good", "display degraded", "fail closed"] },
    { "conditionId": "C10", "conditionName": "latest protection", "purpose": "防止污染 latest", "requiredFields": ["latestWriteAttempted", "latestPointerUpdated", "overwrotePreviousGood", "writeBudget.allowed"], "sourceTableOrView": "receipt / verifier", "passCriteria": "blocked 時皆 false 且 allowed=false", "failCriteria": "blocked/degraded 卻更新 latest", "failureActions": ["preserve previous good", "write blocked receipt", "fail closed"] },
    { "conditionId": "C11", "conditionName": "UI display gate", "purpose": "確認前端走正式 API", "requiredFields": ["/api/institution-latest", "chip route", "mobile fragment"], "sourceTableOrView": "index.html / terminal-chip-flow.js / mobile-fragment.js / fuman-sw.js", "passCriteria": "desktop/mobile/API route exists and forbidden static renderer hits=[]", "failCriteria": "missing route or old static fallback", "failureActions": ["display degraded", "fail closed"] }
  ],
