{
  "version": 2,
  "cleanUrls": true,
  "crons": [
    {
      "path": "/api/desktop-route-snapshot-refresh",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/production-health",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "api/mobile-page.js": {
      "includeFiles": "mobile.html"
    }
  },
  "rewrites": [
    {
      "source": "/88",
      "destination": "/88.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "sec-ch-ua-mobile",
          "value": "\\?1"
        }
      ],
      "destination": "/api/mobile-page"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Android|iPhone|iPad|iPod|Mobile|Windows Phone).*"
        }
      ],
      "destination": "/api/mobile-page"
    },
    {
      "source": "/mobile",
      "destination": "/api/mobile-page"
    },
    {
      "source": "/mobile.html",
      "destination": "/api/mobile-page"
    },
    {
      "source": "/data/realtime-radar-latest.json",
      "destination": "/api/realtime-radar-latest?full=1&limit=1200"
    },
    {
      "source": "/data/(open-buy|strategy2-intraday|strategy3|strategy4|strategy5|institution|warrant-flow|warrant-priority|warrant-single-signal|cb-detect)(.*).json",
      "destination": "/api/desktop-static-disabled"
    }
  ],
  "headers": [
    {
      "source": "/88",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/88.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/mobile",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
