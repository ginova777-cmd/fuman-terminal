{
  "name": "fuman-terminal",
  "version": "0.1.0",
  "private": true,
  "description": "Fuman stock terminal with a Vercel API proxy for official market data.",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "release:main": "pwsh.exe -NoProfile -ExecutionPolicy Bypass -File run-main-release-pipeline.ps1",
    "release": "node scripts/release.js",
    "snapshot:data": "node scripts/commit-data-snapshot.js",
    "cleanup:api-only-retired": "node scripts/cleanup-api-only-retired-artifacts.js",
    "verify:deploy": "node --use-system-ca scripts/verify-deployment.js",
    "verify:deployment": "node --use-system-ca scripts/verify-deployment.js",
    "verify:chip": "node scripts/verify-chip-trade-contract.js",
    "health:chip": "node scripts/health-check-chip-trade.js",
    "verify:contracts": "node scripts/verify-data-contracts.js",
    "verify:mobile": "node --use-system-ca scripts/verify-mobile-health.js && node --use-system-ca scripts/verify-mobile-layout.js --live",
    "verify:mobile-entry": "node scripts/verify-mobile-entry-redirect.js",
    "verify:mobile-layout": "node --use-system-ca scripts/verify-mobile-layout.js",
    "verify:mobile-layout:live": "node --use-system-ca scripts/verify-mobile-layout.js --live",
    "e2e:smoke": "node --use-system-ca scripts/e2e-smoke.js",
    "bump:version": "node scripts/bump-version.js",
    "sync:source": "node scripts/sync-main-deploy-source.js",
    "verify:version": "node scripts/verify-version-consistency.js",
    "predeploy": "node scripts/prepare-deploy.js",
    "postdeploy": "node --use-system-ca scripts/verify-live-version.js --retry && node --use-system-ca scripts/verify-mobile-layout.js --live && node --dns-result-order=ipv4first scripts/verify-mobile-realtime.js && node --dns-result-order=ipv4first scripts/publish-mobile-update-event.js --source=postdeploy",
    "guard:source": "node scripts/guard-source-tree.js",
    "guard:buy-sell-no-rollback": "node scripts/guard-buy-sell-no-rollback.js",
    "guard:production": "node --use-system-ca scripts/verify-production-guard.js",
    "guard:production:pre": "node --use-system-ca scripts/verify-production-guard.js --pre-deploy",
    "verify:live-version": "node --use-system-ca scripts/verify-live-version.js",
    "monitor:production": "node --use-system-ca scripts/monitor-production-health.js",
    "monitor:production:install": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-production-health-monitor-task.ps1",
    "snapshot:desktop": "node --use-system-ca scripts/write-desktop-route-snapshot.js",
    "verify:bump": "node scripts/verify-version-bump-needed.js",
    "verify:supabase-json": "node --use-system-ca scripts/verify-supabase-json.js",
    "verify:sw": "node scripts/verify-service-worker-smoke.js",
    "verify:source-sync": "node scripts/verify-source-sync.js",
    "verify:heatmap": "node --use-system-ca scripts/verify-heatmap-realtime.js",
    "verify:warrant-freshness": "node --use-system-ca scripts/verify-warrant-freshness.js",
    "verify:warrant-freshness:live": "node --use-system-ca scripts/verify-warrant-freshness.js --live",
    "verify:all": "node scripts/verify-all.js",
    "scan:full": "pwsh.exe -NoProfile -ExecutionPolicy Bypass -File ./run-full-scan.ps1",
    "publish:gate": "pwsh.exe -NoProfile -ExecutionPolicy Bypass -File ./run-publish-gate.ps1",
    "release:daily": "pwsh.exe -NoProfile -ExecutionPolicy Bypass -File ./run-daily-release.ps1",
    "freshness:gate": "npm run release:daily",
    "freshness:gate:fast": "pwsh.exe -NoProfile -ExecutionPolicy Bypass -File run-live-freshness-gate.ps1 -Fast",
    "strategy4:publish:fast": "node --use-system-ca scripts/publish-strategy4-fast.js",
    "sync:finmind:quotes": "node --use-system-ca scripts/sync-finmind-quotes-live.js",
    "sync:finmind:daily": "node --use-system-ca scripts/sync-finmind-daily-ohlcv.js",
    "sync:finmind:universe": "node --use-system-ca scripts/sync-finmind-stock-universe.js",
    "sync:finmind:core": "npm run sync:finmind:universe && npm run sync:finmind:daily && npm run sync:finmind:quotes",
    "sync:finmind:chip": "node --use-system-ca scripts/sync-finmind-chip-data.js",
    "sync:finmind:kbar": "node --use-system-ca scripts/sync-finmind-intraday-1m.js",
    "strategy2:coverage": "node --use-system-ca scripts/check-strategy2-supabase-coverage.js",
    "strategy2:coverage:watch": "node --use-system-ca scripts/check-strategy2-supabase-coverage.js --watch --until=09:10",
    "verify:desktop-api-only": "node scripts/verify-desktop-api-only.js",
    "verify:runtime-hotfix": "node --use-system-ca scripts/verify-runtime-hotfix-guard.js",
    "verify:publish-gate": "node scripts/verify-publish-gate.js",
    "sync:tdcc": "node --use-system-ca scripts/sync-tdcc-shareholding-cache.js",
    "sync:tdcc:backfill": "node --use-system-ca scripts/sync-tdcc-shareholding-cache.js --backfill",
    "scan:chip-exclusions": "node scripts/generate-chip-trade-exclusions.js",
    "scan:tdcc-breakout": "node --use-system-ca scripts/generate-institution-tdcc-breakout.js",
    "scan:star": "node --use-system-ca scripts/scan-star-preopen.js",
    "verify:run-gates": "node --use-system-ca scripts/verify-run-id-complete-gates.js",
    "verify:mobile-cache-contract": "node --use-system-ca scripts/verify-mobile-cache-contract.js",
    "verify:mobile-cache-contract:live": "node --dns-result-order=ipv4first --use-system-ca scripts/verify-mobile-cache-contract.js --live",
    "verify:mobile-api-only": "node --use-system-ca scripts/verify-mobile-api-only.js",
    "verify:mobile-api-only:live": "node --dns-result-order=ipv4first --use-system-ca scripts/verify-mobile-api-only.js --live",
    "verify:mobile-ai-fragment": "node scripts/verify-mobile-ai-fragment.js",
    "verify:mobile-ai-fragment:live": "node --dns-result-order=ipv4first --use-system-ca scripts/verify-mobile-ai-fragment.js --live",
    "mobile:update-event": "node --dns-result-order=ipv4first scripts/publish-mobile-update-event.js",
    "verify:mobile-realtime": "node --dns-result-order=ipv4first scripts/verify-mobile-realtime.js",
    "verify:strategy1-open-buy-ui": "node scripts/verify-strategy1-open-buy-ui-contract.js",
    "verify:strategy-direct-main": "node scripts/verify-strategy-direct-main-entry.js"
  },
  "engines": {
    "node": "20.x"
  }
}
